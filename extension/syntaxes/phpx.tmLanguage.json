{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PHPX",
  "scopeName": "source.phpx",
  "patterns": [
    { "include": "#php-tag" },
    { "include": "#phpx-comment" },
    { "include": "#phpx-fragment" },
    { "include": "#phpx-element" },
    { "include": "#template-literal" },
    { "include": "#php-content" }
  ],
  "repository": {
    "php-tag": {
      "begin": "<\\?php",
      "end": "\\?>|(?=<[a-zA-Z]|<>|<\\/>)",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.php" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.php" }
      },
      "name": "meta.embedded.block.php",
      "patterns": [
        { "include": "#phpx-in-php" },
        { "include": "source.php" }
      ]
    },
    "php-content": {
      "patterns": [
        { "include": "source.php" }
      ]
    },
    "phpx-in-php": {
      "patterns": [
        { "include": "#phpx-fragment" },
        { "include": "#phpx-element" },
        { "include": "#template-literal" }
      ]
    },
    "phpx-fragment": {
      "name": "meta.tag.phpx.fragment",
      "begin": "(<>)",
      "end": "(</>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.phpx.fragment.begin" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.phpx.fragment.end" }
      },
      "patterns": [
        { "include": "#phpx-children" }
      ]
    },
    "phpx-element": {
      "patterns": [
        { "include": "#phpx-self-closing-element" },
        { "include": "#phpx-open-close-element" }
      ]
    },
    "phpx-self-closing-element": {
      "name": "meta.tag.phpx.self-closing",
      "begin": "(<)([a-zA-Z][a-zA-Z0-9_-]*)(?=[^>]*/>)",
      "end": "(/>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.phpx" },
        "2": { "name": "entity.name.tag.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.phpx" }
      },
      "patterns": [
        { "include": "#phpx-attributes" }
      ]
    },
    "phpx-open-close-element": {
      "name": "meta.tag.phpx",
      "begin": "(<)([a-zA-Z][a-zA-Z0-9_-]*)(?![^>]*/>)",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.phpx" },
        "2": { "name": "entity.name.tag.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.phpx" },
        "2": { "name": "entity.name.tag.phpx" },
        "3": { "name": "punctuation.definition.tag.end.phpx" }
      },
      "patterns": [
        { "include": "#phpx-opening-tag-end" },
        { "include": "#phpx-children" }
      ]
    },
    "phpx-opening-tag-end": {
      "begin": "(?<=[a-zA-Z0-9_-])",
      "end": "(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.phpx" }
      },
      "patterns": [
        { "include": "#phpx-attributes" }
      ]
    },
    "phpx-attributes": {
      "patterns": [
        { "include": "#phpx-attribute-spread" },
        { "include": "#phpx-attribute-shorthand" },
        { "include": "#phpx-attribute-expression" },
        { "include": "#phpx-attribute-string-double" },
        { "include": "#phpx-attribute-string-single" },
        { "include": "#phpx-attribute-boolean" },
        { "include": "#phpx-attribute-namespace" }
      ]
    },
    "phpx-attribute-spread": {
      "name": "meta.attribute.phpx.spread",
      "match": "(\\{)(\\.\\.\\.)(\\$[a-zA-Z_][a-zA-Z0-9_]*)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.brace.begin.phpx" },
        "2": { "name": "keyword.operator.spread.phpx" },
        "3": { "name": "variable.other.php" },
        "4": { "name": "punctuation.definition.brace.end.phpx" }
      }
    },
    "phpx-attribute-shorthand": {
      "name": "meta.attribute.phpx.shorthand",
      "match": "(\\{)(\\$[a-zA-Z_][a-zA-Z0-9_]*)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.brace.begin.phpx" },
        "2": { "name": "variable.other.php" },
        "3": { "name": "punctuation.definition.brace.end.phpx" }
      }
    },
    "phpx-attribute-expression": {
      "name": "meta.attribute.phpx.expression",
      "begin": "([a-zA-Z_][a-zA-Z0-9_:-]*)(=)(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.phpx" },
        "2": { "name": "punctuation.separator.key-value.phpx" },
        "3": { "name": "punctuation.definition.brace.begin.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.brace.end.phpx" }
      },
      "patterns": [
        { "include": "#phpx-expression-content" }
      ]
    },
    "phpx-attribute-string-double": {
      "name": "meta.attribute.phpx.string",
      "match": "([a-zA-Z_][a-zA-Z0-9_:-]*)(=)(\"[^\"]*\")",
      "captures": {
        "1": { "name": "entity.other.attribute-name.phpx" },
        "2": { "name": "punctuation.separator.key-value.phpx" },
        "3": { "name": "string.quoted.double.phpx" }
      }
    },
    "phpx-attribute-string-single": {
      "name": "meta.attribute.phpx.string",
      "match": "([a-zA-Z_][a-zA-Z0-9_:-]*)(=)('[^']*')",
      "captures": {
        "1": { "name": "entity.other.attribute-name.phpx" },
        "2": { "name": "punctuation.separator.key-value.phpx" },
        "3": { "name": "string.quoted.single.phpx" }
      }
    },
    "phpx-attribute-boolean": {
      "name": "meta.attribute.phpx.boolean",
      "match": "([a-zA-Z_][a-zA-Z0-9_:-]*)(?=\\s|/?>)",
      "captures": {
        "1": { "name": "entity.other.attribute-name.phpx" }
      }
    },
    "phpx-attribute-namespace": {
      "name": "meta.attribute.phpx.namespace",
      "match": "([a-zA-Z_][a-zA-Z0-9_]*):([a-zA-Z_][a-zA-Z0-9_:-]*)(=)(\"[^\"]*\")",
      "captures": {
        "1": { "name": "entity.other.attribute-name.namespace.phpx" },
        "2": { "name": "entity.other.attribute-name.localname.phpx" },
        "3": { "name": "punctuation.separator.key-value.phpx" },
        "4": { "name": "string.quoted.double.phpx" }
      }
    },
    "phpx-children": {
      "patterns": [
        { "include": "#phpx-comment" },
        { "include": "#phpx-fragment" },
        { "include": "#phpx-element" },
        { "include": "#phpx-expression-container" },
        { "include": "#phpx-text" }
      ]
    },
    "phpx-expression-container": {
      "name": "meta.embedded.expression.phpx",
      "begin": "(\\{)(?!/\\*)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.brace.begin.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.brace.end.phpx" }
      },
      "patterns": [
        { "include": "#phpx-expression-content" }
      ]
    },
    "phpx-expression-content": {
      "patterns": [
        { "include": "#phpx-nested-expression" },
        { "include": "#template-literal" },
        { "include": "#phpx-fragment" },
        { "include": "#phpx-element" },
        { "include": "source.php" }
      ]
    },
    "phpx-nested-expression": {
      "name": "meta.embedded.expression.phpx.nested",
      "begin": "(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.brace.begin.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.brace.end.phpx" }
      },
      "patterns": [
        { "include": "#phpx-expression-content" }
      ]
    },
    "phpx-comment": {
      "name": "comment.block.phpx",
      "begin": "(\\{)(/\\*)",
      "end": "(\\*/)(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.brace.begin.phpx" },
        "2": { "name": "punctuation.definition.comment.begin.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.comment.end.phpx" },
        "2": { "name": "punctuation.definition.brace.end.phpx" }
      }
    },
    "phpx-text": {
      "name": "string.unquoted.phpx.text",
      "match": "[^<>{]+"
    },
    "template-literal": {
      "name": "string.template.phpx",
      "begin": "(`)",
      "end": "(`)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.template.begin.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.phpx" }
      },
      "patterns": [
        { "include": "#template-literal-interpolation" },
        {
          "name": "string.template.content.phpx",
          "match": "[^`$]+"
        },
        {
          "name": "string.template.content.phpx",
          "match": "\\$(?!\\{)"
        }
      ]
    },
    "template-literal-interpolation": {
      "name": "meta.embedded.expression.template.phpx",
      "begin": "(\\$\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.interpolation.begin.phpx" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.interpolation.end.phpx" }
      },
      "patterns": [
        { "include": "#phpx-expression-content" }
      ]
    }
  }
}
